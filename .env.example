# ============================================================
# .env.example — 极群科技 Lark HR Bot 环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env
# ⚠️  .env 已加入 .gitignore，绝对不要把真实密钥提交到 Git！
# ============================================================

# 飞书开放平台 - 应用凭证
# 在「开发者后台 → 应用 → 凭证与基础信息」获取
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书事件订阅加密配置（未开启加密可留空）
# 在「开发者后台 → 应用 → 事件与回调 → 加密配置」获取
LARK_ENCRYPT_KEY=
LARK_VERIFICATION_TOKEN=

# 服务端口（GCP VM 上建议用 7777，80 端口需 root）
PORT=7777

# LLM API 配置
LLM_API_URL=https://api.ablai.top/v1/chat/completions
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini
# LLM_MODEL=claude-sonnet-4-5-20241022

# 合同模板目录（默认 ./templates，也可指定绝对路径）
# CONTRACT_TEMPLATES_DIR=/home/lynn/lark-bot-gcp/templates

# 合同输出目录（默认 /tmp）
# CONTRACT_OUTPUT_DIR=/tmp
